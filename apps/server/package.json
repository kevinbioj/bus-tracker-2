{
	"name": "@bus-tracker/server",
	"main": "dist/index.js",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "tsc -b",
		"dev": "pnpm build && pnpm start",
		"package": "pkg",
		"start": "deno run --allow-env --allow-read --allow-net --env-file=.env dist/index.js",
		"migrations:generate": "drizzle-kit generate",
		"migrations:push": "drizzle-kit push"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@bus-tracker/contracts": "workspace:*",
		"@hono/node-server": "^1.19.11",
		"arktype": "^2.2.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.9",
		"postgres": "^3.4.8",
		"redis": "^5.11.0",
		"ts-pattern": "^5.9.0",
		"zod": "^4.3.6"
	}
}
