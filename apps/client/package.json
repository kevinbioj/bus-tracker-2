{
	"name": "@bus-tracker/client",
	"type": "module",
	"private": true,
	"scripts": {
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations",
		"dev": "pnpm run paraglide && vite",
		"build": "pnpm run paraglide && tsc -b && NODE_ENV=production vite build",
		"posthog:sourcemaps": "posthog-cli sourcemap process --directory dist --release-name bus-tracker-client --release-version ${VITE_BUILD_HASH:-dev} --delete-after",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@bus-tracker/contracts": "workspace:*",
		"@inlang/paraglide-js": "^2.18.0",
		"@inlang/plugin-m-function-matcher": "^2.2.6",
		"@inlang/plugin-message-format": "^4.4.0",
		"@posthog/cli": "^0.7.11",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/router-plugin": "^1.167.31",
		"@types/leaflet": "^1.9.21",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"postcss": "^8.5.13",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "8.0.10",
		"vite-plugin-pwa": "^1.2.0"
	},
	"dependencies": {
