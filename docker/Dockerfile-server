FROM node:26.3.1-alpine AS base

##########################################
# STAGE 1 - Build project artifacts      #
##########################################

FROM base AS builder
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
WORKDIR /bus-tracker

RUN npm install -g --force corepack@latest
RUN corepack enable

# Fetch dependencies
COPY pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm fetch

# Install dependencies
COPY scripts/ ./scripts/
COPY libraries/contracts/ ./libraries/contracts/
COPY apps/server/ ./apps/server/
RUN pnpm install -r

# Inject build information
ARG BUILD_HASH
ENV BUILD_HASH=${BUILD_HASH}

# Build server, then upload and remove source maps from the resulting image.
RUN --mount=type=secret,id=posthog_cli_api_key,required=false \
	--mount=type=secret,id=posthog_cli_project_id,required=false \
	--mount=type=secret,id=posthog_cli_host,required=false \
	pnpm -C apps/server exec tsc -b --clean && \
	pnpm -r build && \
	sh scripts/upload-posthog-sourcemaps.sh apps/server apps/server/dist bus-tracker-server "${BUILD_HASH:-dev}"

# Deploy server
RUN pnpm deploy --legacy --filter=@bus-tracker/server --prod server-deployment

##########################################
# STAGE 2 - Run distribution app         #
##########################################

FROM base
ENV NODE_ENV=production

RUN apk add --no-cache curl tini

WORKDIR /bus-tracker/server

# Copy project artifacts
COPY --from=builder /bus-tracker/server-deployment/node_modules ./node_modules/
COPY --from=builder /bus-tracker/server-deployment/drizzle ./drizzle/
COPY --from=builder /bus-tracker/server-deployment/dist ./dist/
COPY --from=builder /bus-tracker/server-deployment/package.json ./package.json

USER node
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/index.js"]
