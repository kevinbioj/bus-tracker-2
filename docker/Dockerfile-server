##########################################
# STAGE 1 - Build project artifacts      #
##########################################

FROM node:25.9.0-alpine AS builder
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
WORKDIR /bus-tracker

RUN npm install -g --force corepack@latest
RUN corepack enable

# Fetch dependencies
COPY pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm fetch

# Install dependencies
COPY libraries/contracts/ ./libraries/contracts/
COPY apps/server/ ./apps/server/
RUN pnpm install -r

# Build server
RUN pnpm -r build

# Deploy server
RUN pnpm deploy --legacy --filter=@bus-tracker/server --prod server-deployment

##########################################
# STAGE 2 - Run distribution app         #
##########################################

FROM denoland/deno:alpine-2.7.12
ENV NODE_ENV=production

RUN apk add --no-cache tini curl

WORKDIR /bus-tracker/server

# Copy project artifacts
COPY --from=builder /bus-tracker/server-deployment/node_modules ./node_modules/
COPY --from=builder /bus-tracker/server-deployment/drizzle ./drizzle/
COPY --from=builder /bus-tracker/server-deployment/dist ./dist/
COPY --from=builder /bus-tracker/server-deployment/package.json ./package.json
COPY --from=builder /bus-tracker/server-deployment/.env ./.env

USER deno
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["deno", "run", "--allow-env", "--allow-read", "--allow-write", "--allow-net", "--env-file=.env", "dist/index.js"]

