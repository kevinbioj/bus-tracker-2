##########################################
# STAGE 1 - Build project artifacts      #
##########################################

FROM node:25.9.0 AS builder
WORKDIR /bus-tracker
RUN npm install -g --force corepack@latest
RUN corepack enable

# Fetch dependencies
# COPY patches/ ./patches/
COPY pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm fetch

# Install dependencies
COPY libraries/contracts/ ./libraries/contracts/
COPY apps/client/ ./apps/client/
RUN pnpm install -r

# Inject build information
ARG BUILD_HASH
ENV VITE_BUILD_HASH=${BUILD_HASH}

ARG BUILD_TIMESTAMP
ENV VITE_BUILD_TIMESTAMP=${BUILD_TIMESTAMP}

# Build client, then upload and remove source maps from the resulting image.
RUN --mount=type=secret,id=posthog_cli_api_key,required=false \
	--mount=type=secret,id=posthog_cli_project_id,required=false \
	--mount=type=secret,id=posthog_cli_host,required=false \
	pnpm -r build && \
	if [ -s /run/secrets/posthog_cli_api_key ] && [ -s /run/secrets/posthog_cli_project_id ]; then \
		export POSTHOG_CLI_API_KEY="$(cat /run/secrets/posthog_cli_api_key)"; \
		export POSTHOG_CLI_PROJECT_ID="$(cat /run/secrets/posthog_cli_project_id)"; \
		if [ -s /run/secrets/posthog_cli_host ]; then export POSTHOG_CLI_HOST="$(cat /run/secrets/posthog_cli_host)"; fi; \
		pnpm -C apps/client posthog:sourcemaps; \
	else \
		echo "Skipping PostHog sourcemap upload because POSTHOG_CLI_API_KEY or POSTHOG_CLI_PROJECT_ID is missing."; \
		find apps/client/dist -name '*.map' -delete; \
	fi

##########################################
# STAGE 2 - Run distribution app         #
##########################################

FROM nginxinc/nginx-unprivileged:1.29.8-alpine AS web

USER root
RUN apk add --no-cache curl tini
USER 101

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/nginx.conf

# Copy build artifacts
WORKDIR /usr/share/nginx/html
COPY --from=builder /bus-tracker/apps/client/dist/ ./

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["nginx", "-g", "daemon off;"]
