##########################################
# STAGE 1 - Build project artifacts      #
##########################################

FROM node:25.9.0 AS builder
WORKDIR /bus-tracker
RUN npm install -g --force corepack@latest
RUN corepack enable

# Fetch dependencies
# COPY patches/ ./patches/
COPY pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm fetch

# Install dependencies
COPY libraries/contracts/ ./libraries/contracts/
COPY apps/client/ ./apps/client/
RUN pnpm install -r

# Inject build information
ARG BUILD_HASH
ENV VITE_BUILD_HASH=${BUILD_HASH}

ARG BUILD_TIMESTAMP
ENV VITE_BUILD_TIMESTAMP=${BUILD_TIMESTAMP}

# Build client
RUN pnpm -r build

##########################################
# STAGE 2 - Run distribution app         #
##########################################

FROM nginxinc/nginx-unprivileged:1.29.5-alpine AS web

USER root
RUN apk add --no-cache curl tini
USER 101

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/nginx.conf

# Copy build artifacts
WORKDIR /usr/share/nginx/html
COPY --from=builder /bus-tracker/apps/client/dist/ ./

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["nginx", "-g", "daemon off;"]
